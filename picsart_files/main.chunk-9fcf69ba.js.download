SMBs launch and build their businesses.",title:"Small Business Evangelist",uuid:Object(ue.d)()},{description:"You run a blog, newsletter, website, or other online community and reach over 10K people each month.",title:"Content Curator",uuid:Object(ue.d)()}]},testimonialsData:{title:"TESTIMONIALS",itemProps:[{quoteText:"“Your search is over. 😍PicsArt is simply superior to many of the other editing tools around! ❤️”",userName:"Yuka S.",uuid:Object(ue.d)()},{quoteText:"“Absolutely amazing!!! 🥰I love that you can add stickers, text, and more!!!“",userName:"Cayla B.",uuid:Object(ue.d)()},{quoteText:"“I love PicsArt! You can do a ton of things with it including social media ads, images for websites and a logo for your business. Highly Recommended! 🔥”",userName:"John R.",uuid:Object(ue.d)()}]},summaryHelpData:my,joinButtonData:{mobileUrl:"https://app.impact.com/campaign-promo-signup/PicsArt.brand?execution=e64s1",url:"https://app.impact.com/campaign-promo-signup/PicsArt.brand?execution=e64s1",label:"Join Now",gtmValue:"2"},promotionData:{description:"Apply now or email us at affiliates@picsart.com",title:"Partner With Us!",buttonProps:{label:"Join Now",mobileLink:"https://app.impact.com/campaign-promo-signup/PicsArt.brand?execution=e64s1",link:"https://app.impact.com/campaign-promo-signup/PicsArt.brand?execution=e64s1",secondary:!1,gtmValue:"3"}},landingData:{description:[{uuid:Object(ue.d)(),title:"World’s Largest Creative Community",description:"PicsArt is the most downloaded photo & video editor globally"},{uuid:Object(ue.d)(),title:"Over 150 Million Monthly Active Users",description:"We’re growing fast! Partner with a world-class company and earn$"},{uuid:Object(ue.d)(),title:"Thousands of Tools",description:"They’re easy-to-use and available on desktop and mobile (iOS, Android, Windows)"},{uuid:Object(ue.d)(),title:"#FreeToEdit Content ",description:"Access billions of amazing images and one-of-a-kind stickers"},{uuid:Object(ue.d)(),title:"Impressive Video Editor",description:"Create awesome video edits with special effects in minutes — no professional experience required! "},{uuid:Object(ue.d)(),title:"Available in 30+ Languages",description:"PicsArt empowers storytelling. Everywhere."}],title:"The Power of PicsArt",imageUrl:"https://cdn130.picsart.com/92395466763570585821.png",imageAlt:"girl having sunflowers in hair posing with vintage effect applied",bgPosition:"bgToLeft"},bannerData:{imageAlt:"boy in trendy outfit and colorful glasses on a gold coins background with picsart sketch effect applied",description:"<p>Inspire others to start their storytelling journey.</p>",imageUrl:"https://cdn130.picsart.com/96746580161744524912.png",title:"Be Creative. Earn Money With PicsArt Gold.",strongTitle:"PICSART AFFILIATE PROGRAM",bgImage:!0,lightText:!0,buttonProps:{label:"Join Now",mobileUrl:"https://app.impact.com/campaign-promo-signup/PicsArt.brand?execution=e64s1",url:"https://app.impact.com/campaign-promo-signup/PicsArt.brand?execution=e64s1",gtmValue:"1"}},screenName:"picsart_affiliate_program",cardData:dy},gy=o(73),fy=o.n(gy),yy=function(){return(yy=Object.assign||function(e){for(var t,o=1,r=arguments.length;o<r;o++)for(var n in t=arguments[o])Object.prototype.hasOwnProperty.call(t,n)&&(e[n]=t[n]);return e}).apply(this,arguments)},by=hy.summaryPartnerData,vy=hy.testimonialsData,ky=hy.summaryHelpData,wy=hy.joinButtonData,Py=hy.promotionData,Ey=hy.landingData,xy=hy.bannerData,Ty=hy.screenName,Ay=hy.cardData,Ny=[{width:"min-width: 1366px",r:{width:478}},{width:"min-width: 1024px",r:{width:376}},{width:"min-width: 768px",action:ue.a.crop,r:{width:672,height:440}},{width:"min-width: 0",action:ue.a.crop,r:{width:312,height:204}}],Oy=function(e){var t=e.isAmp,o=void 0!==t&&t;return It(Ty,"apps"),l.a.createElement(fn,{isAmp:o},l.a.createElement(py,yy({},xy,{dataTests:{actionButton:"primary-button"}})),l.a.createElement(ly,{joinButtonData:wy,className:fy.a.button,title:"How It Works",data:Ay}),l.a.createElement(ey,{className:fy.a.help,data:ky,type:"triple"}),l.a.createElement(Xf,yy({},Ey,{media:Ny})),l.a.createElement(ey,{data:by,type:"double"}),l.a.createElement(eu,yy({containerClassName:fy.a.testimonialSectionContainer},vy,{isAmp:o})),l.a.createElement(Hr,{containerClassName:fy.a.promotionSectionContainer,description:Py.description,buttonProps:Py.buttonProps,className:fy.a.promotion,title:Py.title,isAmp:o}))},_y=[[{index:1,pointDescription:"Upload your image or choose from our free-to-edit options."},{index:2,pointDescription:"Let the AI detect the sky."},{index:3,pointDescription:"Browse through other sky options."}],[{index:4,pointDescription:"Apply a new sky."},{index:5,pointDescription:"Download your work."}]],jy=[{description:"<p>Imagine taking a picture to promote your product, an outdoor family portrait, or photographing the architecture in a foreign city. Everything is perfect; but you wish the sky in the background was a bit different. Whether you want a beautiful blue sky, something more gray and dramatic, night-time instead of daylight, or a colorful sunset; all of this is possible with PicsArt. Our Change Sky tool uses AI to identify the sky in your images. Once the AI detects the sky in your photo, you can choose a replacement from our library of skies. Editing a sky can be a very complicated process, requiring knowledge of professional software, or instead of all that, you can replace the sky in your photos using this easy-to-use sky editor with just a few clicks.</p>",title:"Change Sky Uses AI Technology",imageUrl:"https://cdn130.picsart.com/64034448167975874764.png",imageAlt:"",buttonProps:{url:"/create/editor?category=sky-effects",mobileUrl:"/create/editor",label:"Change the Sky",gtmValue:"2"}}],Sy={description:"<p>Replace the sky in any image. </p>",title:"Introducing PicsArt’s New Change Sky Tool ",imageUrl:"https://cdn140.picsart.com/40298929973214269384.png",buttonProps:{url:"/create/editor?category=sky-effects",mobileUrl:"/create/editor",label:"Change the Sky",gtmValue:"1"}},Cy="change_sky",Ry=!0,Iy=function(){return(Iy=Object.assign||function(e){for(var t,o=1,r=arguments.length;o<r;o++)for(var n in t=arguments[o])Object.prototype.hasOwnProperty.call(t,n)&&(e[n]=t[n]);return e}).apply(this,arguments)},Uy=function(e){var t=e.isAmp,o=void 0!==t&&t,r=_y,n=jy,a=Sy,i=Cy,s=Ry;return It(i),l.a.createElement(fn,{isAmp:o},l.a.createElement(Tn,Iy({},a,{screenName:i,isPremium:s,isAmp:o,dataTests:{actionButton:"primary-button"}})),l.a.createElement(kr,{productData:n,screenName:i,isPremium:s,isAmp:o}),l.a.createElement(Gn,{isAmp:o,title:"How to Change the Sky in Your Image",data:r}),l.a.createElement(ha,{isAmp:o}))},My=[[{index:1,pointDescription:"Upload your picture or choose one from our #FreeToEdit images."},{index:2,pointDescription:"Click on the “Crop tool” within Tools."}],[{index:3,pointDescription:"Pick a template or choose freestyle cropping."},{index:4,pointDescription:"Click “Apply” then download your work."}]],Wy=[{description:"<p>No matter how beautiful a photo is, it can almost always use some cropping. Cropping just means removing parts of any photo to alter its size. It can be done for various reasons, mainly to cut out objects, white space, or background noise. Sometimes you want to crop the tops and sides of a photo to help direct the focus to a certain element or person. Some cropping needs are large, while other images just need a small amount of cropping. No matter your photo cropping needs, PicsArt’s Crop tool can handle it with no sweat off your back. </p>",title:"What Is Cropping Exactly?",imageUrl:"https://cdn130.picsart.com/89803168574550326586.png",imageAlt:"blond hair girl with red ugly sweater sitting ",buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"2"}},{description:"<p>With PicsArt’s free cropping tool, you can give your shots an even more flawless finish by cutting out a little — or in some cases, a lot. It all depends on the composition of the image and the end result you want. The best part is that it won’t cost you a penny to take your photos from simple to simply stunning. You, your wallet, and photo will all be pleased!</p>",title:"It Won’t Cost a Thing!",imageUrl:"https://cdn130.picsart.com/85134163697440619055.PNG",imageAlt:"couple laying in bed surrounded by guitar, pictures, food with pink filter",imageToRight:!0,bgPosition:"bgToRight",buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"3"}},{description:'<p>Nobody has time to deal with difficult editing tools. That’s why PicsArt’s easy-to-use Crop tool is the perfect companion for your photo cropping needs. What’s more, we have convenient pre-made templates for Instagram (square, portrait, and story), Facebook (post or cover), Pinterest (post), Twitter (post and header), and YouTube (banner). You can use one image for all your social channels to keep things consistent. Easily save your edits to upload to your social accounts. Consider layering on <a href="/add-stickers-to-photos" target="_blank" class="inline-link" data-test="a-sticker-or-two-hypertext">a sticker or two</a> for added fun.</p>',title:"It’s Easy to Use For Social Media",imageUrl:"https://cdn140.picsart.com/34769807188799205008.png",imageAlt:"short hair girl with long summer dress in posing",buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"4"}},{description:'<p>Whether it’s a zoomed-in product shot, a stylized model photo shoot, or a lively photo of you and your friends, cropping will come in handy in all instances. All you have to do is upload the photo you want to crop, then either use one of our pre-made templates or go the freeform route. Next, play with the image placement until you’re happy with the end result. You can also choose from aspect ratio presets to be precise. Get rid of extra white space, say goodbye to the building in the background with our <a href="/background-changer" target="_blank" class="inline-link" data-test="background-changer-hypertext">Background Changer</a> or <a href="/background-remover" target="_blank" class="inline-link" data-test="background-remover-hypertext">Background Remover</a>, or center the photo for an even more eye-catching finish. Turn landscape shots into portraits or the perfect profile pic. </p>',title:"Cropping Works for Professional and Personal Shots",imageUrl:"https://cdn140.picsart.com/75801735494517718366.png",imageAlt:"curly hair girl with trendy band and black glasses and white summer dress",imageToRight:!0,buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"5"}},{description:'<p> One of the neatest things about PicsArt’s cropping tool is that no matter what size you decide to cut your image down to, it doesn’t tamper with the quality. The last thing you want is a low-resolution photo at the end of this process. Rest assured that your images will be high resolution from start to finish. You can also choose to <a href="/image-upscale" target="_blank" class="inline-link" data-test="upscale-your-images-hypertext">upscale your images</a>, meaning enlarge them without losing resolution.</p>',title:"Crop Tool Maintains Photo Quality",imageUrl:"https://cdn140.picsart.com/44303225557516314639.png",imageAlt:"coffee cup with colorful liquid in surrounded by green leaves and sweets",bgPosition:"bgToLeft",buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"6"}},{description:"<p>Would you believe it if we told you that you can get all your photo cropping done in just a single click? It’s true! Upload the image you want to crop into our photo cutter, then click on the pre-made template that fits your needs, play around with the positioning of the image, then save. That’s it.  </p>",title:"Crop Photos in One Click (Really!)",imageUrl:"https://cdn140.picsart.com/30019700756375527513.png",imageAlt:"girls having fun on the sand in the sunny beach",imageToRight:!0,bgPosition:"bgToRight",buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"7"}}],Dy={description:"<p>Our Crop tool will give your photos a more focused, stunning look in seconds.  </p>",title:"Crop Images Instantly and Easily With PicsArt",imageUrl:"https://cdn130.picsart.com/32146206211679938961.png",imageAlt:"short black hair gril in the field with sketch effect",buttonProps:{url:"/create/editor?cropOpen=true",mobileUrl:"https://picsart.app.link/ge6b5Lcmt8",label:"Crop Image",gtmValue:"1"}},Fy="crop_image",Ly=!0,Vy=function(){return(Vy=Object.assign||function(e){for(var t,o=1,r=arguments.length;o<r;o++)for(var n in t=arguments[o])Object.prototype.hasOwnProperty.call(t,n)&&(e[n]=t[n]);return e}).apply(this,arguments)},zy=function(e){var t=e.isAmp,o=void 0!==t&&t,r=My,n=Wy,a=Dy,i=Fy,s=Ly;return It(i),l.a.createElement(fn,{isAmp:o},l.a.createElement(Tn,Vy({isPremium:s},a,{screenName:i,isAmp:o,dataTests:{actionButton:"primary-button"}})),l.a.createElement(Hr,{isAmp:o,description:l.a.createElement("p",{"data-test":"description"},"Anytime you need to crop pictures, turn to PicsArt’s Crop tool in our ",l.a.createElement(Re,{href:"/photo-editor",target:"_blank",className:"inline-link"},"Photo Editor")," to get it done with zero fuss. Crop images online using our pre-sized social media templates or go the freestyle route. In a few taps, quickly cut down the size of any image. Whether you need to crop a photo for framing purposes or to fit your website, let us help you achieve the look you want — for free.")}),l.a.createElement(kr,{productData:n,screenName:i,isPremium:s,isAmp:o}),l.a.createElement(Gn,{isAmp:o,title:"How to Crop Photos With PicsArt",data:r}),l.a.createElement(ha,{isAmp:o}))},qy=function(){return(qy=Object.assign||function(e){for(var t,o=1,r=arguments.length;o<r;o++)for(var n in t=arguments[o])Object.prototype.hasOwnProperty.call(t,n)&&(e[n]=t[n]);return e}).apply(this,arguments)},By=[[{index:1,pointDescription:"Open the Card Maker tool."},{index:2,pointDescription:"Upload your own image or use one from our #FreeToEdit library."}],[{index:3,pointDescription:"Edit any design details using our editing tools."},{index:4,pointDescription:"Download your online card."}]],Hy=[{description:"<p>When it comes to cards, personalization is the way to ensure your message stands out and speaks to the heart. With PicsArt’s Card Maker, you’ll get all the help you need in creating the most beautiful customized online cards you can find. And it’ll only take a few minutes. We offer a handful of easy-to-use editing tools that will lend a unique, one-of-a-kind feel to your online cards. Design stylish cards using beautiful fonts, fun stickers, trending effects, bold backgrounds, and more. Just click on the tools you’d like to use, then make any changes within the editor to reflect the look you’re going for. You can incorporate your own images into your personalized card or pick a photo from our extensive #FreeToEdit library. The creative possibilities are endless!</p>",title:"PicsArt’s Personalized Cards Made for Any Occasion",imageUrl:"https://cdn130.picsart.com/25156378943980874535.png",imageAlt:"happy birthday card template",buttonProps:{url:"/create/editor?templateSearch=card",mobileUrl:"https://picsart.app.link/H9esjKsaV7",label:"Make a Card",gtmValue:"2"}},{description:"<p>With time being of the essence, the last thing you want to do is spend hours designing an online card. With PicsArt’s Card Maker by your side, you don’t have to. It’ll only take a few minutes to dream up an online card that’s truly beautiful and conveys your message in style. And with the help of our intuitive editing tools, you can personalize your card as much or as little as you wish. Pick the tools that work for your project, then click on them to start customizing your card. Add your own image to make something even more one-of-a-kind. Then send your high-quality card virtually or choose to print it to hand out in person. No matter which avenue you choose, PicsArt can help you with an online card that you’ll truly be proud to share.</p>",title:"Online Card Making That’s Fast & Easy",imageUrl:"https://cdn140.picsart.com/08301522559604293293.png",imageAlt:"thank you card template design",imageToRight:!0,buttonProps:{url:"/create/editor?templateSearch=card",mobileUrl:"https://picsart.app.link/H9esjKsaV7",label:"Make a Card",gtmValue:"3"}},{description:"<p>Another option to consider when creating a card online is to use PicsArt’s handy card templates. This route is even quicker than starting from scratch. Designed by our talented team, you can find hundreds of easy-to-use card templates in many styles and colors. From simple to bold, we’ve got a look that will match your occasion. Personalize all templates with our easy-to-use editing tools at your convenience. When creating a card using one of our templates, you can upload your own image or you can choose a photo from our extensive #FreeToEdit image library. Like a card template but want to edit some details? No problem. All of our card templates are fully customizable at any time.</p>",title:"Try Creative and Modern Card Templates",imageUrl:"https://cdn130.picsart.com/38624625655472569315.png",imageAlt:"wedding invitation card template design",buttonProps:{url:"/create/editor?templateSearch=card",mobileUrl:"https://picsart.app.link/H9esjKsaV7",label:"Make a Card",gtmValue:"4"}},{description:"<p>When making an online card, the last thing you want to do is send out a card that’s low resolution. At PicsArt, all of our card templates are designed with the highest quality, ensuring that you won’t experience any quality issues. Whether you decide to share your online card virtually or have it printed to hand in out in person, your final result will be crisp and sleek. Each of our card templates is created with the same high-quality in mind, so you never have to worry about quality issues.</p>",title:"High-Quality Templates for Outstanding Online Cards",imageUrl:"https://cdn140.picsart.com/22975078802973081440.png",imageAlt:"europe trip, enjoy your holidays with us tour agency card template ",imageToRight:!0,bgPosition:"bgToRight",buttonProps:{url:"/create/editor?templateSearch=card",mobileUrl:"https://picsart.app.link/H9esjKsaV7",label:"Make a Card",gtmValue:"5"}},{description:"<p>When it comes to online cards, our team of talented designers at PicsArt has spent countless hours dreaming up beautiful ideas to make your special occasions even more thoughtful. Whether you’re sending out a card for a birthday, anniversary, wedding, or any special holiday, we can assure you that your final card will be one-of-a-kind once you personalize the details to fit your needs. With the help of our stylized fonts, fun stickers, bold backgrounds, and unique effects, you can make an online card that they’ll love to receive.</p>",title:"One-of-a-Kind Card Designs to Stand Out in Style",imageUrl:"https://cdn140.picsart.com/48818410816915017463.png",imageAlt:"summer party card template design",buttonProps:{url:"/create/editor?templateSearch=card",mobileUrl:"https://picsart.app.link/H9esjKsaV7",label:"Make a Card",gtmValue:"6"}}],Yy={description:"<p>Create standout custom cards with our online Card Maker within minutes</p>",title:"PicsArt’s Card Maker Is Your Go-To for Personalized Cards",imageUrl:"https://cdn140.picsart.com/43584710385359038346.png",imageAlt:"hope you will get well soon card template design",buttonProps:{url:"/create/editor?templateSearch=card",mobileUrl:"https://picsart.app.link/H9esjKsaV7",label:"Make a Card",gtmValue:"1"}},Gy="card_maker",Xy=!0,Qy=function(e){var t=e.isAmp,o=void 0!==t&&t;return It(Gy),l.a.createElement(fn,{isAmp:o},l.a.createElement(Tn,qy({},Yy,{screenName:Gy,isPremium:Xy,isAmp:o,dataTests:{actionButton:"primary-button"}})),l.a.createElement(Hr,{isAmp:o,description:l.a.createElement("p",{"data-test":"description"},"PicsArt’s Card Maker gives you infinite ideas on creating your very own custom online card within minutes. Design a personalized card for business or personal purposes with the help of our easy-to-use editing tools. Share it virtually or print your high-quality card to hand out in person. Create cards online from the convenience of your own home for any occasion. From holidays to birthdays to anniversaries to weddings and more, we provide everything you need to make something truly unique with PicsArt. Customize the look of your online card as much or as little as you wish. Add eye-catching effects, stickers, text, backgrounds, and colors to make your special message resonate with your audience.")}),l.a.createElement(kr,{productData:Hy,screenName:Gy,isPremium:Xy,isAmp:o}),l.a.createElement(Gn,{isAmp:o,title:"How to Make a Card Online",data:By}),l.a.createElement(ha,{isAmp:o}))},Ky=[[{index:1,pointDescription:"Upload your video."},{index:2,pointDescription:"Click on the Format tool."},{index:3,pointDescription:"Select which social media format you’d like your video to fit into."}],[{index:4,pointDescription:"Apply the selected format and preview your video."},{index:5,pointDescription:"Fit or Fill the canvas for each video in your project."},{index:6,pointDescription:"Download the output video and start sharing!"}]],$y=[{description:"Crop videos within seconds. No need to spend hours on editing."},{description:"PicsArt’s video cropper is easy-to-use."},{description:"Multiple video formats supported, including MOV, MP4, AVI, WEBM, FLV, and more."}],Jy=[{description:'<p>Videos are an inseparable part of our newsfeeds. Most of the content we see and engage with today comes from top social media channels like Facebook, Instagram, and Twitter. As you may have noticed, businesses, influencers, and bloggers have more than one social media channel, but a video uploaded to one of them may not look as good on the other. For such cases, PicsArt’s <a href="/video-editor" class="inline-link" target="_blank" data-test="video-editor-hypertext">Video Editor</a> provides you with the tools you need to quickly crop your videos and fit them into various formats. Cropping videos for specific social media channels is an important step in the overall editing process. Your videos should appear whole - showing every inch of the content you’ve put together.</p>',imageUrl:"https://cdn140.picsart.com/28787041414625069546.png",imageAlt:"man in glasses sitting on a sofa giving interview",title:"Crop Videos for Your Social Media Channels",buttonProps:{url:"/create/video/",mobileUrl:"https://picsart.app.link/Sw1HvRaEocb",label:"Crop Video",gtmValue:"2"}},{description:'<p>Producing content at a steady and quick rate can be difficult to maintain. You want to make sure you have all of the necessary video editing tools to optimize the entire editing process. PicsArt’s video cropper provides you with presets of the most popular social media formats. Easily <a href="/resize-video" class="inline-link" target="_blank" data-test="resize-your-video-hypertext">resize your video</a> to 1:1 (square), 16:9 (horizontal),  9:16, and 4:5 (vertical). All you have to do is click on the preset, preview your video, and export it.</p>',imageUrl:"https://cdn140.picsart.com/56373833775431893847.png",imageAlt:"couple having picnic in park near a lake",title:"Cut Down Time Spent on Editing With Our Video Cropper",bgPosition:"bgToRight",imageToRight:!0,buttonProps:{url:"/create/video/",mobileUrl:"https://picsart.app.link/Sw1HvRaEocb",label:"Crop Video",gtmValue:"3"}}],Zy="crop_videos",eb={description:"<p>Easily crop videos to fit social media dimensions.</p>",imageUrl:"https://cdn130.picsart.com/78265549763306068522.png",title:"Crop Videos Online With PicsArt",imageAlt:"man with a backpack climbing mountains",lightText:!1,bgImage:!0,buttonProps:{url:"/create/video/",mobileUrl:"https://picsart.app.link/Sw1HvRaEocb",label:"Crop Video",gtmValue:"1"}},tb=!0,ob=o(112),rb=o.n(ob),nb=function(){return(nb=Object.assign||function(e){for(var t,o=1,r=arguments.length;o<r;o++)for(var n in t=arguments[o])Object.prototype.hasOwnProperty.call(t,n)&&(e[n]=t[n]);return e}).apply(this,arguments)},ab=Ky,ib=$y,sb=Jy,lb=Zy,cb=eb,ub=tb,pb=function(e){var t=e.isAmp,o=void 0!==t&&t;return It(lb),l.a.createElement(fn,{isAmp:o},l.a.createElement(Tn,nb({dataTests:{actionButton:"primary-button"},className:rb.a.backgroundToLeft,screenName:lb,isPremium:ub},cb,{isAmp:o})),l.a.createElement(Hr,{description:l.a.createElement("p",{"data-test":"description"},"PicsArt’s video cropper is your go-to tool for fitting your videos into specific social media dimensions. There are various video formats and size requirements depending on which social media platform you’re posting on. PicsArt enables you to crop videos online for your social media posts and stories alike. Our cropping tool comes with preset dimensions for Instagram, Facebook, YouTube, Snapchat, TikTok, and more. You don’t have to worry about your video being reduced at the edges. In case you have landscape videos, you can simply fill the borders of your video to make sure your content keeps its quality and form."),isAmp:o}),l.a.createElement(kr,{productData:sb,screenName:lb,isPremium:ub,isAmp:o}),l.a.createElement(Hr,{dataTests:{title:"title data test",description:"description data test"},title:"Benefits",isAmp:o}),l.a.createElement(Ya,{featuresData:ib,isAmp:o}),l.a.createElement(Gn,{title:"How to Crop a Video",data:ab,isAmp:o}),l.a.createElement(ha,{isAmp:o}))},db=function(){return(db=Object.assign||function(e){for(var t,o=1,r=arguments.length;o<r;o++)for(var n in t=arguments[o])Object.prototype.hasOwnProperty.call(t,n)&&(e[n]=t[n]);return e}).apply(this,arguments)},mb={label:"Get Free App",mobileUrl:"https://picsart.app.link/TIVYc9ZjNu"};Mf="phone"===ue.c?{title:"Make Awesome Photos & Videos",descriptio